!DOCTYPE html>
<html lang="sw">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wingu Drive</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="topbar">
    <div class="brand">
      <span class="brand-mark">☁</span>
      <span class="brand-name">Wingu<span class="brand-accent">Drive</span></span>
    </div>
    <p class="tagline">Pakia. Shiriki. Pakua. Popote ulipo.</p>
  </header>

  <main class="wrap">
    <section class="upload-card">
      <h2 class="eyebrow">01 — Pakia faili</h2>
      <% if (error) { %>
        <div class="alert"><%= error %></div>
      <% } %>
      <form action="/upload" method="POST" enctype="multipart/form-data" class="upload-form">
        <label class="file-drop" for="file-input">
          <span class="file-drop-text" id="file-label">Bonyeza kuchagua faili (kikomo 100MB)</span>
          <input id="file-input" type="file" name="file" required
                 onchange="document.getElementById('file-label').textContent = this.files[0]?.name || 'Bonyeza kuchagua faili'" />
        </label>
        <button type="submit" class="btn-primary">Pakia sasa</button>
      </form>
    </section>

    <section class="files-card">
      <h2 class="eyebrow">02 — Mafile yako (<%= files.length %>)</h2>

      <% if (files.length === 0) { %>
        <p class="empty">Bado hakuna faili. Pakia la kwanza hapo juu.</p>
      <% } else { %>
        <ul class="file-list">
          <% files.forEach(function(f) { %>
            <li class="ticket">
              <div class="ticket-main">
                <p class="ticket-name"><%= f.original %></p>
                <p class="ticket-meta"><%= f.size %> · <%= f.date %></p>
              </div>
              <div class="ticket-actions">
                <a class="btn-ghost" href="/download/<%= f.stored %>">Pakua</a>
                <button class="btn-ghost copy-btn" data-path="/download/<%= f.stored %>">Nakili link</button>
                <form action="/delete/<%= f.stored %>" method="POST"
                      onsubmit="return confirm('Una uhakika unataka kufuta ' + <%- JSON.stringify(f.original) %> + '?');">
                  <button class="btn-danger" type="submit">Futa</button>
                </form>
              </div>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </section>
  </main>

  <footer class="footer">
    <p>Mradi huu ni huru (open source) — fork, badilisha, deploy yako mwenyewe.</p>
  </footer>

  <script>
    document.querySelectorAll(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const url = window.location.origin + btn.dataset.path;
        navigator.clipboard.writeText(url).then(() => {
          const old = btn.textContent;
          btn.textContent = "Imenakiliwa ✓";
          setTimeout(() => (btn.textContent = old), 1500);
        });
      });
    });
  </script>
</body>
</html>

